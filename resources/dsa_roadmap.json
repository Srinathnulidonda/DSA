                "id": "w2_project",
                "title": "Text Analyzer Tool",
                "description": "Build a comprehensive text analysis tool with multiple features",
                "requirements": [
                    "Word and character counting",
                    "Frequency analysis of words and letters",
                    "Reading level assessment",
                    "Pattern detection (emails, URLs, phone numbers)",
                    "Text statistics (avg word length, sentence count)",
                    "File input/output support",
                    "GUI interface",
                    "Export results to different formats"
                ],
                "technologies": [
                    "Python",
                    "Tkinter",
                    "RegEx",
                    "Collections",
                    "NLTK (optional)"
                ],
                "estimatedTime": "4-6 hours",
                "difficulty": "intermediate",
